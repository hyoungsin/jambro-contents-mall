# Server
PORT=5000
NODE_ENV=development

# MongoDB — Atlas 우선(연결 실패 시 아래 MONGODB_URI로 폴백). db.js 참고
# MONGODB_ATLAS=mongodb+srv://user:pass@cluster.mongodb.net/dbname
MONGODB_URI=mongodb://localhost:27017/jambro-contents-mall

# 포트원(구 아임포트) REST API — 결제·본인인증(휴대폰) 검증용(https://admin.portone.io 에서 발급)
# IAMPORT_API_KEY=
# IAMPORT_API_SECRET=
# 본인인증: 콘솔에서 휴대폰 본인인증 사용 설정 후, 클라이언트 IMP.certification → POST /api/certifications/verify
# 개발만: 검증 없이 imp_uid로 paid 처리(운영에서는 사용 금지)
# IAMPORT_ALLOW_UNVERIFIED_COMPLETE=1

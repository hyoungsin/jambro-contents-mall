# API — 로컬: 비워 두면 Vite가 /api → localhost:5000 프록시 (vite.config.js)
# 프로덕션(Vercel): Heroku 백엔드 origin만 (예: https://your-app.herokuapp.com)
# VITE_API_BASE_URL=https://your-app.herokuapp.com

# 포트원 가맹점 식별코드 (IMP.init)
# VITE_IAMPORT_MERCHANT_CODE=imp00000000

# KG이니시스 결제창 등
# VITE_IAMPORT_PG=html5_inicis

# 휴대폰 본인인증(IMP.certification) — 콘솔 「채널 관리」에서 채널 속성이 「본인인증」인 채널의 키만 사용
# VITE_PORTONE_CERT_CHANNEL_KEY=channel-key-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
